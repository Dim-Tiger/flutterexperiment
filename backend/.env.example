# =============================================================================
# MUSIC PRACTICE PLATFORM - BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and configure the values below for your environment.
# All variables marked as REQUIRED must be set for the application to work.
# Variables marked as OPTIONAL have fallback defaults but should be configured
# for production environments.

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================

# NODE_ENV - Application environment mode
# Values: development | production | test
# - development: Enables detailed logging, error traces, and development tools
# - production: Optimized for performance, minimal logging, security headers
# - test: Used for automated testing with special configurations
# Default: development
NODE_ENV=development

# PORT - Server port number
# The port on which the Express server will listen for incoming requests
# Range: 1-65535 (typically 3000-8080 for development, 80/443 for production)
# Default: 3000
PORT=3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# DATABASE_URL - PostgreSQL connection string (REQUIRED)
# Full PostgreSQL connection URL including credentials, host, port, and database name
# Format: postgresql://username:password@hostname:port/database_name
# Example: postgresql://musicapp:secretpass@localhost:5432/music_practice_db
# 
# For production:
# - Use strong passwords and restricted database users
# - Enable SSL by adding ?sslmode=require to the URL
# - Consider connection pooling for high-traffic applications
DATABASE_URL=postgresql://username:password@localhost:5432/music_practice_db

# REDIS_URL - Redis connection string (REQUIRED)
# Redis is used for session storage, caching, and real-time features
# Format: redis://[username:password@]hostname:port[/database_number]
# Example: redis://localhost:6379 or redis://user:pass@redis-server:6379/0
#
# For production:
# - Use Redis AUTH with strong passwords
# - Consider Redis Cluster for high availability
# - Enable persistence (RDB/AOF) for data durability
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT_SECRET - Secret key for signing JWT access tokens (REQUIRED)
# Used to sign and verify JWT tokens for user authentication
# IMPORTANT: Must be a strong, random string of at least 32 characters
# Generate with: openssl rand -base64 32
# Never share this secret or commit it to version control
JWT_SECRET=your-super-secret-jwt-key-here

# JWT_EXPIRES_IN - Access token expiration time
# How long access tokens remain valid before requiring refresh
# Format: Use time units like '15m', '1h', '7d', '30d'
# Recommendation: 15m-24h for security, 7d for convenience
# Default: 7d
JWT_EXPIRES_IN=7d

# JWT_REFRESH_SECRET - Secret key for signing refresh tokens (REQUIRED)
# Must be different from JWT_SECRET for security
# Used for long-term token refresh functionality
# Generate with: openssl rand -base64 32
JWT_REFRESH_SECRET=your-refresh-token-secret

# JWT_REFRESH_EXPIRES_IN - Refresh token expiration time
# How long refresh tokens remain valid
# Recommendation: 30d-90d, should be longer than JWT_EXPIRES_IN
# Default: 30d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# MEDIA STORAGE (CLOUDINARY)
# =============================================================================

# CLOUDINARY_CLOUD_NAME - Your Cloudinary cloud name (REQUIRED for file uploads)
# Found in your Cloudinary dashboard
# Used for storing user avatars, practice session recordings, and other media
# Example: my-music-app-cloud
CLOUDINARY_CLOUD_NAME=your-cloud-name

# CLOUDINARY_API_KEY - Your Cloudinary API key (REQUIRED for file uploads)
# Found in your Cloudinary dashboard under API Keys
# Used for authenticating API requests to Cloudinary
CLOUDINARY_API_KEY=your-api-key

# CLOUDINARY_API_SECRET - Your Cloudinary API secret (REQUIRED for file uploads)
# Found in your Cloudinary dashboard under API Keys
# Keep this secret secure and never expose in client-side code
CLOUDINARY_API_SECRET=your-api-secret

# =============================================================================
# PAYMENT PROCESSING (STRIPE) - OPTIONAL
# =============================================================================

# STRIPE_SECRET_KEY - Stripe secret key for payment processing (OPTIONAL)
# Required only if you want to enable marketplace payments
# Use test keys (sk_test_) for development, live keys (sk_live_) for production
# Found in your Stripe dashboard under API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# STRIPE_WEBHOOK_SECRET - Stripe webhook endpoint secret (OPTIONAL)
# Required for processing Stripe webhook events securely
# Found in your Stripe dashboard under Webhooks
# Format: whsec_followed by the secret string
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# EMAIL CONFIGURATION - OPTIONAL
# =============================================================================
# Currently prepared for future email features (password reset, notifications)
# Not actively used in current implementation

# EMAIL_HOST - SMTP server hostname
# Examples: smtp.gmail.com, smtp.sendgrid.net, localhost
EMAIL_HOST=smtp.gmail.com

# EMAIL_PORT - SMTP server port
# Common ports: 587 (TLS), 465 (SSL), 25 (unsecured)
# Recommendation: Use 587 with TLS for security
EMAIL_PORT=587

# EMAIL_USER - SMTP authentication username
# Usually your email address for services like Gmail
EMAIL_USER=your-email@gmail.com

# EMAIL_PASS - SMTP authentication password
# For Gmail, use an App Password instead of your regular password
# Generate at: https://support.google.com/accounts/answer/185833
EMAIL_PASS=your-app-password

# =============================================================================
# SECURITY & RATE LIMITING
# =============================================================================

# RATE_LIMIT_WINDOW_MS - Rate limiting time window in milliseconds
# Time period for rate limit calculations
# Example: 900000 = 15 minutes, 3600000 = 1 hour
# Default: 900000 (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# RATE_LIMIT_MAX_REQUESTS - Maximum requests per time window
# Number of requests allowed per IP within the time window
# Recommendation: 100-1000 depending on your needs
# Default: 100
RATE_LIMIT_MAX_REQUESTS=100

# ALLOWED_ORIGINS - CORS allowed origins (REQUIRED for web apps)
# Comma-separated list of allowed origins for CORS
# Include your frontend domain(s) and any development servers
# Examples: https://myapp.com,https://www.myapp.com
# For development: http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# MAX_FILE_SIZE - Maximum file upload size in bytes
# Limits the size of uploaded files (avatars, media, etc.)
# Example: 10485760 = 10MB, 52428800 = 50MB
# Recommendation: 10MB for avatars, 50MB+ for audio/video
# Default: 10485760 (10MB)
MAX_FILE_SIZE=10485760

# MAX_FILES_PER_REQUEST - Maximum number of files per upload request
# Limits how many files can be uploaded in a single request
# Recommendation: 1-10 depending on your use case
# Default: 5
MAX_FILES_PER_REQUEST=5

# =============================================================================
# CONFIGURATION NOTES
# =============================================================================
#
# SECURITY BEST PRACTICES:
# 1. Use strong, unique secrets for JWT tokens (minimum 32 characters)
# 2. Enable SSL/TLS in production (DATABASE_URL, REDIS_URL with SSL)
# 3. Restrict ALLOWED_ORIGINS to your actual domain(s)
# 4. Use environment-specific values (test/staging/production)
# 5. Never commit real secrets to version control
#
# PERFORMANCE TUNING:
# 1. Adjust rate limits based on your expected traffic
# 2. Configure Redis with appropriate memory limits
# 3. Set reasonable file upload limits
# 4. Monitor database connection pools
#
# DEVELOPMENT TIPS:
# 1. Use local databases for development
# 2. Set shorter JWT expiration times for testing
# 3. Use test Stripe keys for payment testing
# 4. Enable detailed logging with NODE_ENV=development
#
# =============================================================================